{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "../dist-server",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "./**/*.ts",
    "../clients/electron/git.ts",
    "../clients/electron/ollama.ts",
    "../clients/electron/tools.ts",
    "../clients/electron/worktree.ts",
    "../clients/electron/state.ts"
  ]
}
